// Mighty Rides - Premium Automotive Dealership Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Vehicle Inventory (Cars for Sale)
model Vehicle {
  id            String   @id @default(cuid())
  make          String
  model         String
  year          Int
  price         Int
  mileage       Int
  engine        String
  transmission  String
  fuelType      String
  bodyType      String
  color         String
  condition     String   // "New", "Used", "Certified Pre-Owned"
  description   String?
  features      String?  // JSON string of features
  images        String?  // JSON string of image URLs
  isFeatured    Boolean  @default(false)
  isSold        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  inquiries     VehicleInquiry[]
}

// Rental Vehicles
model RentalVehicle {
  id            String   @id @default(cuid())
  name          String
  make          String
  model         String
  year          Int
  category      String   // "Wedding", "Airport Pickup", "Corporate", "VIP", "Events", "Long-term"
  dailyRate     Int
  weeklyRate    Int?
  monthlyRate   Int?
  description   String?
  features      String?  // JSON string
  images        String?  // JSON string
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  inquiries     RentalInquiry[]
}

// Vehicle Inquiry (Sales)
model VehicleInquiry {
  id              String   @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  name            String
  email           String
  phone           String
  preferredContact String? // "Phone", "Email", "WhatsApp"
  message         String?
  status          String   @default("New") // "New", "Contacted", "Viewing Scheduled", "Closed"
  createdAt       DateTime @default(now())
}

// Rental Inquiry
model RentalInquiry {
  id              String   @id @default(cuid())
  rentalId        String
  rental          RentalVehicle @relation(fields: [rentalId], references: [id])
  name            String
  email           String
  phone           String
  occasion        String?  // Wedding, Corporate, Airport, etc.
  startDate       String?
  endDate         String?
  message         String?
  status          String   @default("New")
  createdAt       DateTime @default(now())
}

// Car Sourcing Request
model SourcingRequest {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  preferredMake   String?
  preferredModel  String?
  yearFrom        Int?
  yearTo          Int?
  budgetMin       Int?
  budgetMax       Int?
  preferredColor  String?
  condition       String?
  timeline        String?
  message         String?
  status          String   @default("New")
  createdAt       DateTime @default(now())
}

// Service Inquiry
model ServiceInquiry {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  serviceType     String   // "Servicing", "Maintenance", "Customization", "Detailing", "Spare Parts", "Inspection"
  vehicleInfo     String?
  message         String?
  status          String   @default("New")
  createdAt       DateTime @default(now())
}

// General Contact
model ContactMessage {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  subject         String?
  message         String
  status          String   @default("New")
  createdAt       DateTime @default(now())
}

// Testimonials
model Testimonial {
  id              String   @id @default(cuid())
  name            String
  role            String?
  company         String?
  content         String
  rating          Int      @default(5)
  vehiclePurchased String?
  image           String?
  isFeatured      Boolean  @default(true)
  createdAt       DateTime @default(now())
}

// Blog Posts
model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String?
  content         String
  category        String   // "Buying Guide", "Maintenance", "Premium Ownership", "Imports", "Rental Insights"
  featuredImage   String?
  author          String?
  isPublished     Boolean  @default(true)
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Services
model Service {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String
  icon            String?
  benefits        String?  // JSON string
  isFeatured      Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Team Members
model TeamMember {
  id              String   @id @default(cuid())
  name            String
  role            String
  bio             String?
  image           String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
}
